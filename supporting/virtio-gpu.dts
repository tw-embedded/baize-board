/dts-v1/;

/ {
    /* #*cells are here to keep DTC happy */
    #address-cells = <2>;
    #size-cells = <2>;

    passthrough {
        compatible = "simple-bus";
        ranges;
        #address-cells = <2>;
        #size-cells = <2>;
        virtio_mmio@20002e00 {
            compatible = "virtio,mmio";
            reg = <0x0 0x20002e00 0x0 0x200>;
            /* interrupt-parent = <&gicv3>; */
            interrupts = <0x0 0x19 0x1>;
            dma-coherent;
            status = "okay";
        };
    };
};

